generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GalleryImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String
  category  String
  createdAt DateTime @default(now())
}

model Notice {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  category  String
  date      DateTime @default(now())
  createdAt DateTime @default(now())
}

model TeamMember {
  id          Int      @id @default(autoincrement())
  name        String
  position    String
  image       String   @default("")
  description String
  socials     Json     @default("[]")
  createdAt   DateTime @default(now())
}
